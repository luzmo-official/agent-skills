# Copy this file to .env and fill in your real credentials.
# This repository does not auto-load .env, so export these variables
# in your shell before running commands.

# For generic_http adapter with Anthropic endpoint
ANTHROPIC_API_KEY=

# For generic_http adapter with OpenAI endpoint
OPENAI_API_KEY=

# For Luzmo API scripts/examples
LUZMO_API_KEY=
LUZMO_API_TOKEN=

# Optional Luzmo endpoint overrides
LUZMO_API_HOST=https://api.luzmo.com